# Google Sheets (required for booking form)
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}
GOOGLE_SHEET_ID=your_google_sheet_id

# Optional: worksheet tab for full /book form (default: Sheet1). Must match the tab name in Google Sheets exactly.
# GOOGLE_SHEET_BOOKINGS_TAB=Bookings

# Optional: worksheet tab for home-page quote form (default: QuoteLeads)
# GOOGLE_SHEET_QUOTES_TAB=QuoteLeads

# Resend (optional - email notification on new booking)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
BOOKING_NOTIFY_EMAIL=your@email.com

# Site URL (for SEO canonical URLs)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
